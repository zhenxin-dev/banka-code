# Provider: openai | openai-chat | anthropic
# openai: OpenAI Responses API（默认，仅 OpenAI 官方支持）
# openai-chat: OpenAI Chat Completions API（第三方兼容服务请用这个）
# anthropic: Anthropic 原生 API
BANKA_PROVIDER=openai

# API Key（必填，Ollama 等本地服务随意填一个即可）
BANKA_API_KEY=your-api-key

# API 端点（必填）
# OpenAI:       https://api.openai.com/v1
# Anthropic:    https://api.anthropic.com
# Ollama:       http://127.0.0.1:11434/v1
# GLM (智谱):    https://open.bigmodel.cn/api/coding/paas/v4
# Kimi:         https://api.kimi.com/coding/v1
# MiniMax:      https://api.minimaxi.com/v1
# Qwen (通义):   https://dashscope.aliyuncs.com/compatible-mode/v1
# Xiaomi (MiMo): https://api.xiaomimimo.com/v1
BANKA_BASE_URL=https://api.openai.com/v1

# 模型名称（必填）
BANKA_MODEL=gpt-4
